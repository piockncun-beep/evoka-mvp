
import { SignedIn, SignedOut, useAuth } from "@clerk/clerk-react";
grep -n "onClick" src/routes/Dashboard.tsx
import { useState } from "react";
import { Navigate } from "react-router-dom";
import { apiFetch } from "../lib/api";
import { sendEvent } from "../lib/telemetry";

type Memory = {
  id: string;
  content: string;
  summary: string;
  emotion: string;
  topics: string[];
  question: string;
  created_at: string;
};
type RelatedMemory = Memory & { similarity?: number };


export default function Dashboard() {
  const { getToken } = useAuth();
  const [content, setContent] = useState("");
  const [destiny, setDestiny] = useState("self");
  const [visibility, setVisibility] = useState("private");
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [prime, setPrime] = useState<null | {
    memory: Memory;
    analysis: { summary: string; emotion: string; topics: string[]; question: string };
    related: RelatedMemory[];
  }>(null);
  const [feedbackSent, setFeedbackSent] = useState<null | boolean>(null);
  const [feedbackLoading, setFeedbackLoading] = useState(false);
  const [showFeedbackComment, setShowFeedbackComment] = useState(false);
  const [feedbackComment, setFeedbackComment] = useState("");
  const [search, setSearch] = useState("");
  const [searchResults, setSearchResults] = useState<RelatedMemory[]>([]);
  const [searchLoading, setSearchLoading] = useState(false);
  const [searchError, setSearchError] = useState<string | null>(null);

  async function handleCreate(e: React.FormEvent) {
    e.preventDefault();
    setError(null);
    setLoading(true);
    setPrime(null);
    setFeedbackSent(null);
    try {
      const token = await getToken();
      if (!token) throw new Error("Falta token de autenticación");
      const data = await apiFetch("/api/memories", {
        method: "POST",
        body: { content, destiny, visibility },
        token,
      });
      setPrime(data);
      // Telemetría
      sendEvent("memory_created", {
        destiny,
        visibility,
        content_length: content.length,
        related_count: data.related?.length || 0,
      }, token);
      setContent("");
    } catch (err: any) {
      setError(err?.error || "No se pudo guardar. Intenta nuevamente.");
    } finally {
      setLoading(false);
    }
  }

  async function handleFeedback(is_positive: boolean, comment?: string) {
    if (!prime?.memory?.id) return;
    setFeedbackLoading(true);
    setError(null);
    try {
      const token = await getToken();
      if (!token) throw new Error("Falta token de autenticación");
      await apiFetch(`/api/memories/${prime.memory.id}/feedback`, {
        method: "POST",
        body: { signal: is_positive, comment },
        token,
      });
      setFeedbackSent(is_positive);
      sendEvent(is_positive ? "prime_thumb_up" : "prime_thumb_down", {
        memory_id: prime.memory.id,
        comment: comment || undefined,
      }, token);
    } catch (err: any) {
      setError(err?.error || "No se pudo enviar feedback.");
    } finally {
      setFeedbackLoading(false);
      setShowFeedbackComment(false);
      setFeedbackComment("");
    }
  }

  async function handleSearch(e: React.FormEvent) {
    e.preventDefault();
    setSearchError(null);
    setSearchLoading(true);
    setSearchResults([]);
    try {
      const token = await getToken();
      if (!token) throw new Error("Falta token de autenticación");
      const data = await apiFetch("/api/memories/search", {
        method: "POST",
        body: { query: search },
        token,
      });
      setSearchResults(data.results?.slice(0, 10) || []);
      sendEvent("semantic_search_used", { query: search, result_count: data.results?.length || 0 }, token);
    } catch (err: any) {
      setSearchError(err?.error || "No se pudo buscar. Intenta nuevamente.");
    } finally {
      setSearchLoading(false);
    }
  }

  return (
    <>
      <SignedOut>
        <Navigate to="/sign-in" />
      </SignedOut>
      <SignedIn>
        <div className="min-h-screen bg-neutral-950 text-white p-4 max-w-2xl mx-auto">
          <h2 className="text-3xl font-bold mb-4">Dashboard</h2>
          <form onSubmit={handleCreate} className="mb-6 bg-neutral-900 p-4 rounded">
            <label className="block mb-2 font-semibold">Nueva memoria</label>
            <textarea
              className="w-full p-2 mb-1 bg-neutral-800 text-white rounded resize-none"
              placeholder="Escribe tu memoria (mín 10, máx 10000 caracteres)"
              minLength={10}
              maxLength={10000}
              required
              value={content}
              onChange={e => setContent(e.target.value)}
              rows={5}
              disabled={loading}
              style={{ lineHeight: '1.5', fontFamily: 'inherit' }}
            />
            <div className="flex justify-between items-center mb-2 text-xs text-neutral-400">
              <span>{content.length} / 10000</span>
              {content.length > 0 && content.length < 10 && <span className="text-yellow-400">Mínimo 10 caracteres</span>}
              {content.length > 10000 && <span className="text-red-400">Máximo 10000 caracteres</span>}
            </div>
            <div className="flex gap-2 mb-2">
              <select value={destiny} onChange={e => setDestiny(e.target.value)} className="bg-neutral-800 p-2 rounded" disabled={loading}>
                <option value="self">Para mí</option>
                <option value="kids">Para mis hijos</option>
                <option value="partner">Para mi pareja</option>
                <option value="someone_lost">Para alguien que perdí</option>
              </select>
              <select value={visibility} onChange={e => setVisibility(e.target.value)} className="bg-neutral-800 p-2 rounded" disabled={loading}>
                <option value="private">Privada</option>
                <option value="public">Pública</option>
              </select>
            </div>
            <button type="submit" className="bg-blue-600 px-4 py-2 rounded" disabled={loading || content.length < 10 || content.length > 10000}>
              {loading ? "Guardando…" : "Guardar"}
            </button>
            {error && <div className="text-red-400 mt-2">{error}</div>}
          </form>

          {prime && (
            <div className="mb-6 bg-neutral-900 p-4 rounded">
              <h3 className="text-xl font-bold mb-2">Análisis PRIME</h3>
              {/* Summary editorial, clamp 3 líneas */}
              <div className="mb-2 relative">
                <span className="block font-semibold mb-1">Resumen:</span>
                <SummaryClamp text={prime.analysis.summary} />
              </div>
              <div className="mb-2">
                <span className="font-semibold">Emoción:</span> {prime.analysis.emotion}
              </div>
              <div className="mb-2 flex flex-wrap gap-2 items-center">
                <span className="font-semibold">Temas:</span>
                {prime.analysis.topics.slice(0, 5).map((t) => (
                  <span key={t} className="bg-blue-800 px-2 py-1 rounded text-xs">{t}</span>
                ))}
                {prime.analysis.topics.length > 5 && (
                  <span className="bg-neutral-700 px-2 py-1 rounded text-xs">+{prime.analysis.topics.length - 5}</span>
                )}
              </div>
              <div className="mb-2">
                <div className="bg-neutral-800 rounded p-3 text-sm text-neutral-300 italic border border-neutral-700">
                  {prime.analysis.question}
                </div>
              </div>
              <div className="mt-4 flex gap-2 items-center">
                <button
                  className="bg-green-700 px-3 py-1 rounded disabled:opacity-50"
                  disabled={feedbackSent !== null || feedbackLoading}
                  onClick={() => handleFeedback(true)}
                >👍 Esto me representa</button>
                <button
                  className="bg-yellow-700 px-3 py-1 rounded disabled:opacity-50"
                  disabled={feedbackSent !== null || feedbackLoading}
                  onClick={() => setShowFeedbackComment(true)}
                >👎 No es exactamente</button>
                {feedbackSent !== null && (
                  <span className="ml-2 text-green-400">Gracias por tu feedback.</span>
                )}
              </div>
              {/* Feedback comment opcional */}
              {showFeedbackComment && feedbackSent === null && (
                <form
                  className="mt-3 flex flex-col gap-2"
                  onSubmit={e => {
                    e.preventDefault();
                    handleFeedback(false, feedbackComment);
                  }}
                >
                  <textarea
                    className="w-full p-2 bg-neutral-800 text-white rounded resize-none"
                    placeholder="¿Qué no calza? (opcional)"
                    value={feedbackComment}
                    onChange={e => setFeedbackComment(e.target.value)}
                    rows={2}
                    disabled={feedbackLoading}
                  />
                  <div className="flex gap-2">
                    <button type="submit" className="bg-yellow-700 px-3 py-1 rounded" disabled={feedbackLoading}>
                      Enviar feedback
                    </button>
                    <button type="button" className="bg-neutral-700 px-3 py-1 rounded" onClick={() => setShowFeedbackComment(false)} disabled={feedbackLoading}>
                      Cancelar
                    </button>
                  </div>
                </form>
              )}
            </div>
          )}

          {/* Relacionados */}
          {(prime?.related?.length ?? 0) > 0 && (
            <div className="mb-6 bg-neutral-900 p-4 rounded">
              <h4 className="font-semibold mb-2">Esto se conecta con...</h4>
              <ul>
                {(prime?.related ?? []).slice(0, 5).map((rel) => (
                  <li key={rel.id} className="mb-2 border-b border-neutral-800 pb-2">
                    <div className="text-sm text-neutral-300">{rel.summary || rel.content.slice(0, 80) + '...'}</div>
                    <div className="text-xs text-neutral-500">{rel.created_at ? new Date(rel.created_at).toLocaleString() : ''}</div>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* Search opcional */}
          <form onSubmit={handleSearch} className="mb-6 bg-neutral-900 p-4 rounded">
            <label className="block mb-2 font-semibold">Buscar memorias (semántica)</label>
            <input
              type="text"
              className="w-full p-2 mb-2 bg-neutral-800 text-white rounded"
              placeholder="Buscar..."
              value={search}
              onChange={e => setSearch(e.target.value)}
              disabled={searchLoading}
            />
            <button type="submit" className="bg-blue-600 px-4 py-2 rounded" disabled={searchLoading || !search.trim()}>
              {searchLoading ? "Buscando..." : "Buscar"}
            </button>
            {searchError && <div className="text-red-400 mt-2">{searchError}</div>}
          </form>
          {searchResults.length > 0 && (
            <div className="mb-6 bg-neutral-900 p-4 rounded">
              <h4 className="font-semibold mb-2">Resultados de búsqueda</h4>
              <ul>
                {searchResults.map((rel) => (
                  <li key={rel.id} className="mb-2 border-b border-neutral-800 pb-2">
                    <div className="text-sm text-neutral-300">{rel.summary || rel.content.slice(0, 80) + '...'}</div>
                    <div className="text-xs text-neutral-500">{rel.created_at ? new Date(rel.created_at).toLocaleString() : ''}</div>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </SignedIn>
    </>
  );
}

function SummaryClamp({ text }: { text: string }) {
  const [expanded, setExpanded] = useState(false);
  const clampStyle = expanded
    ? ({} as React.CSSProperties)
    : ({
        display: '-webkit-box',
        WebkitLineClamp: 3,
        WebkitBoxOrient: 'vertical' as any,
        overflow: 'hidden',
        textOverflow: 'ellipsis',
      } as React.CSSProperties);
  return (
    <>
      <p style={clampStyle} className="text-neutral-200 leading-relaxed whitespace-pre-line">{text}</p>
      {!expanded && text.split(' ').length > 30 && (
        <button className="text-blue-400 text-xs mt-1" onClick={() => setExpanded(true)} type="button">Ver más</button>
      )}
      {expanded && (
        <button className="text-blue-400 text-xs mt-1" onClick={() => setExpanded(false)} type="button">Ver menos</button>
      )}
    </>
  );
}

